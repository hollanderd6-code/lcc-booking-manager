{
  "appId": "com.boostinghost.app",
  "appName": "Boostinghost",
  "webDir": "public",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#7fd3a6",
      "androidSplashResourceName": "splash",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#7fd3a6",
      "overlaysWebView": false
    },
    "Haptics": {
      "enabled": true
    }
  }
}
