{
  "appId": "com.boostinghost.app",
  "appName": "Boostinghost",
  "webDir": "public",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "launchAutoHide": true,
      "launchFadeOutDuration": 300,
      "backgroundColor": "#7fd3a6",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#7fd3a6",
      "overlaysWebView": false
    }
  },
  "ios": {
    "backgroundColor": "#7fd3a6",
    "contentInset": "automatic"
  }
}
