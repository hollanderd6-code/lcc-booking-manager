{
  "appId": "com.boostinghost.app",
  "appName": "Boostinghost",
  "webDir": "public",
  "backgroundColor": "#7fd3a6",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 10000,
      "launchAutoHide": false,
      "backgroundColor": "#7fd3a6",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  },
  "ios": {
    "backgroundColor": "#7fd3a6",
    "contentInset": "automatic",
    "scrollEnabled": true
  }
}
