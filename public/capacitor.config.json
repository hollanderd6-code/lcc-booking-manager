{
  "appId": "com.boostinghost.app",
  "appName": "Boostinghost",
  "webDir": "public",
  "backgroundColor": "#7fd3a6",
  "server": {
    "url": "https://lcc-booking-manager.onrender.com",
    "cleartext": true
  },
  "ios": {
    "backgroundColor": "#7fd3a6"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 8000,
      "launchAutoHide": true,
      "backgroundColor": "#7fd3a6",
      "showSpinner": true,
      "iosSpinnerStyle": "large",
      "spinnerColor": "#ffffff"
    }
  }
}
